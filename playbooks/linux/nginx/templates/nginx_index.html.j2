<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ ansible_hostname }} — ansible-aws-lab</title>
  <style>
    body { font-family: monospace; background: #0f3460; color: #e0e0e0; padding: 40px; }
    h1   { color: #e94560; }
    .box { background: #16213e; border-left: 4px solid #00d4ff; padding: 20px; margin: 20px 0; border-radius: 4px; }
    .label { color: #a0a0c0; }
    .value { color: #00d4ff; }
  </style>
</head>
<body>
  <h1>Nginx — Test Page</h1>
  <div class="box">
    <p><span class="label">Hostname    : </span><span class="value">{{ ansible_hostname }}</span></p>
    <p><span class="label">FQDN        : </span><span class="value">{{ ansible_fqdn }}</span></p>
    <p><span class="label">Public IP   : </span><span class="value">{{ ansible_host }}</span></p>
    <p><span class="label">OS          : </span><span class="value">{{ ansible_distribution }} {{ ansible_distribution_version }}</span></p>
    <p><span class="label">Kernel      : </span><span class="value">{{ ansible_kernel }}</span></p>
    <p><span class="label">Port        : </span><span class="value">{{ nginx_port }}</span></p>
    <p><span class="label">Managed by  : </span><span class="value">Ansible — ansible-aws-lab</span></p>
    <p><span class="label">Deployed at : </span><span class="value">{{ ansible_date_time.iso8601 }}</span></p>
  </div>
</body>
</html>
